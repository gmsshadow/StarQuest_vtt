<form class="sq-enemy {{#unless editable}}locked{{/unless}}">
  <header class="sq-header">
    <img class="sq-portrait" src="{{actor.img}}" data-edit="img" alt="portrait"/>
    <div class="sq-identity">
      <input type="text" name="name" value="{{actor.name}}" placeholder="Name" class="sq-name"/>
      <div class="sq-levelrow">
        <label>Size <input type="number" name="system.unitSize" value="{{system.unitSize}}" min="1"/></label>
        <label>Pts <input type="number" name="system.pointCost" value="{{system.pointCost}}" min="0"/></label>
      </div>
    </div>
  </header>

  <section class="sq-stats">
    <div class="sq-stat" data-action="rollStat" data-stat="quality">
      <span class="sq-stat-label">Quality</span><span class="sq-stat-value">{{system.quality}}+</span>
    </div>
    <div class="sq-stat" data-action="rollStat" data-stat="defense">
      <span class="sq-stat-label">Defense</span><span class="sq-stat-value">{{system.defense}}+</span>
    </div>
    <div class="sq-stat sq-tough">
      <span class="sq-stat-label">Toughness</span><span class="sq-stat-value">{{system.toughness}}</span>
    </div>
  </section>

  <section class="sq-vitals">
    <div class="sq-wounds">
      <label>Wounds</label>
      <input type="number" name="system.wounds" value="{{system.wounds}}" min="0"/>
      <span class="sq-of">/ {{system.toughness}}</span>
      {{#if system.isDefeated}}<span class="sq-down">DEFEATED</span>{{/if}}
    </div>
  </section>

  <section class="sq-block">
    <h3>Weapons</h3>
    <table class="sq-table">
      <thead><tr><th>Name</th><th>Rng</th><th>A</th><th>AP</th><th>Special</th><th></th></tr></thead>
      <tbody>
        {{#each weapons}}
        <tr data-item-id="{{id}}">
          <td>{{name}}</td>
          <td>{{#if system.isMelee}}Melee{{else}}{{system.range}}{{/if}}</td>
          <td>{{system.attacks}}</td>
          <td>{{system.ap}}</td>
          <td>{{system.special}}</td>
          <td class="sq-rowbtns">
            <button type="button" data-action="editItem">✎</button>
            <button type="button" data-action="deleteItem">🗑</button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </section>

  <section class="sq-block">
    <h3>Special Rules</h3>
    {{#each specialRules}}
    <div data-item-id="{{id}}" class="sq-rule">
      <span>{{name}}</span>
      <button type="button" data-action="editItem">✎</button>
      <button type="button" data-action="deleteItem">🗑</button>
    </div>
    {{/each}}
  </section>
</form>
